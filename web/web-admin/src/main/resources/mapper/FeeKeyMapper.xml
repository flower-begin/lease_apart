<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.atguigu.lease.web.admin.mapper.FeeKeyMapper">

    <resultMap id="aMp" type="com.atguigu.lease.web.admin.vo.fee.FeeKeyVo">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <collection property="feeValueList" ofType="com.atguigu.lease.web.admin.vo.fee.FeeValueVo">
            <id property="id" column="fv_id"/>
            <result property="name" column="fv_name"/>
            <result property="feeKeyId" column="fee_key_id"/>
        </collection>
    </resultMap>

    <select id="feeInfoList" resultMap="aMp">
        select fk.id,fk.name,fv.id fv_id,fv.name fv_name,fv.fee_key_id
        from fee_key fk left join
             fee_value fv on fk.id = fv.fee_key_id and fv.is_deleted = 0
        where fk.is_deleted = 0;
    </select>
</mapper>
